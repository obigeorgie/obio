[Unit]
Description=MasteryGraph Core API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/.openclaw/workspace
ExecStart=/usr/bin/python3 -m uvicorn masterygraph_api:app --host 0.0.0.0 --port 8000 --log-level warning
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
